{
    "name": "newsolari/tags",
    "description": "Tags module for SolariWebOS",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "newsolari/core": "^1.0 || @dev"
        "newsolari/identity": "^1.0 || @dev",
    },
    "autoload": {
        "psr-4": {
            "NewSolari\\Tags\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NewSolari\\Tags\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NewSolari\\Tags\\TagsServiceProvider"
            ]
        }
    }
}
