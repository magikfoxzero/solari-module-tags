APP_NAME=TagsService
APP_ENV=production
APP_KEY=
APP_DEBUG=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=solari_db
DB_USERNAME=solari_user
DB_PASSWORD=

JWT_SECRET=
JWT_ALGORITHM=HS256

CACHE_STORE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

CORS_ALLOWED_ORIGINS=https://console.kismetdrift.com,https://www.kismetdrift.com,https://api.kismetdrift.com,https://ws.kismetdrift.com,https://kismetdrift.com,https://kismet-console.solarinet.org,https://kismet-api.solarinet.org,https://kismet-ws.solarinet.org,https://app.kismetdrift.com,https://console.solarinet.org,https://app.solarinet.org,https://api.solarinet.org
CORS_SUPPORTS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Multi-domain support (CORS, cookies, passkey RP ID)
ALLOWED_DOMAINS=solarinet.org,kismetdrift.com

# Shared secret for service-to-service authentication
SERVICE_TOKEN=
